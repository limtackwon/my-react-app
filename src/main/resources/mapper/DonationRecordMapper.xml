<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.myreactapp.mapper.DonationRecordMapper">

    <resultMap id="donationMap" type="com.example.myreactapp.dto.DonationRecordDto">
        <id     property="id"        column="id"/>
        <result property="date"      column="date"/>
        <result property="recipient" column="recipient"/>
        <result property="category"  column="category"/>
        <result property="amount"    column="amount"/>
        <result property="status"    column="status"/>
    </resultMap>

    <!-- 전체 조회 (최신순) -->
    <select id="findAll" resultMap="donationMap">
        SELECT id, date, recipient, category, amount, status
        FROM donation_records
        ORDER BY date DESC
    </select>

    <!-- 건수 조회 -->
    <select id="count" resultType="long">
        SELECT COUNT(*) FROM donation_records
    </select>

    <!-- 등록 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO donation_records (date, recipient, category, amount, status)
        VALUES (#{date}, #{recipient}, #{category}, #{amount}, #{status})
    </insert>

</mapper>
